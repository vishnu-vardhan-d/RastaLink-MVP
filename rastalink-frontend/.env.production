# ========================================
# PRODUCTION CONFIGURATION ONLY
# ========================================
# This file is exclusively for production deployment
# Never modify this for local development

VITE_APP_NAME=RastaLink
VITE_APP_ENV=production
VITE_DEBUG=false
VITE_LOG_LEVEL=error

# Production API Endpoints
VITE_API_URL=https://api.rastalink.in/api
VITE_WEBSOCKET_URL=wss://api.rastalink.in/api/ws
VITE_MOCK_API=false

# Production Features
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_REPORTING=true
VITE_ENABLE_HOT_RELOAD=false
VITE_SHOW_DEBUG_INFO=false

# Production Database
VITE_DB_TYPE=postgresql

# Production Monitoring (Set via environment variables)
VITE_SENTRY_DSN=${SENTRY_DSN}
VITE_GOOGLE_ANALYTICS_ID=${GA_TRACKING_ID}
VITE_NEW_RELIC_LICENSE_KEY=${NEW_RELIC_KEY}