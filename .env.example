# RastaLink Environment Configuration

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/rastalink

# Server Configuration
PORT=5000
NODE_ENV=development

# Session Configuration
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# API Keys (add as needed)
# WEATHER_API_KEY=your_weather_api_key
# MAPS_API_KEY=your_maps_api_key
# SMS_API_KEY=your_sms_api_key

# Replit Configuration (automatically set in Replit)
# REPLIT_DB_URL=automatically_set_by_replit
# REPL_ID=automatically_set_by_replit
# REPL_SLUG=automatically_set_by_replit